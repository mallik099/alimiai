# HuggingFace API Token (required for text generation)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Groq API Key (optional - for faster text generation)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Configure model settings
HUGGINGFACE_MODEL=microsoft/DialoGPT-medium
GROQ_MODEL=llama-3.1-8b-instant

# Optional: Image generation settings
STABLE_DIFFUSION_MODEL=runwayml/stable-diffusion-v1-5
MAX_IMAGE_SIZE=512

# Google OAuth (required for /auth/google)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Session TTL in seconds (default 7 days)
SESSION_TTL_SECONDS=604800

# Comma-separated origins allowed to call backend from browser
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
